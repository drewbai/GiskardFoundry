{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://giskardfoundry.local/schemas/agent_manifest.schema.json",
  "title": "GiskardFoundry Agent Manifest",
  "type": "object",
  "required": [
    "name",
    "description",
    "version",
    "tools",
    "instructions"
  ],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "display_name": {
      "type": "string"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "domain": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "entrypoint": {
      "type": "string",
      "pattern": "^[a-zA-Z_][a-zA-Z0-9_\\.]*:[A-Za-z_][A-Za-z0-9_]*$"
    },
    "prompt_file": {
      "type": "string"
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "instructions": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "properties": {
            "system_prompt_ref": {
              "type": "string"
            },
            "operating_policy": {
              "type": "string"
            }
          },
          "additionalProperties": true
        }
      ]
    },
    "input_schema": {
      "type": "object"
    },
    "output_schema": {
      "type": "object"
    },
    "mvp": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "orchestrator": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "routing_tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}