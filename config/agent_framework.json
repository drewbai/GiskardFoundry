{
  "framework": "microsoft-agent-framework",
  "version": "1.0.0rc3",
  "manifest_schema": "config/agent_manifest_schema.json",
  "orchestrator": {
    "entrypoint": "orchestrator.orchestrator:Susan_Calvin",
    "runner_entrypoint": "orchestrator.runner:run_susan_calvin_server",
    "strategy": "manifest-routing"
  },
  "hosting": {
    "adapter": "azure.ai.agentserver.agentframework.from_agent_framework",
    "protocol": "http"
  },
  "agent_registry": [
    "onenote_agent",
    "gtd_agent",
    "jobsearch_agent"
  ],
  "notes": "Configured for Microsoft Agent Framework with Foundry-compatible runner wiring."
}